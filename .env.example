# FESI runtime configuration — copy to .env and fill in.
# .env is gitignored. NEVER commit secrets.

# ---- Mode & environment ----
MODE=shadow                  # shadow | paper | live
ENVIRONMENT=local            # local | prod
TZ=Asia/Dubai

# ---- Database ----
DATABASE_URL=sqlite:///./data/fesi.db

# ---- LLM APIs ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
VOYAGE_API_KEY=

# ---- Market data ----
POLYGON_API_KEY=
TIINGO_API_KEY=

# ---- Broker (Interactive Brokers DFSA Dubai branch) ----
# Phase 4+ — leave blank until paper account is opened
IBKR_API_USERNAME=
IBKR_API_PASSWORD=
IBKR_ACCOUNT_ID=
IBKR_PAPER=true

# ---- Notifications ----
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
